<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gayatri_widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/widgetAppName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="Gayatri Time"
        android:textColor="#8B7355"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widgetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="2"
        android:paddingTop="6dp"
        android:text="Gayatri Time"
        android:textColor="#4A3728"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widgetNext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="Open the app to calculate"
        android:textColor="#6B4F3A"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/widgetLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:singleLine="true"
        android:paddingTop="6dp"
        android:text="Location"
        android:textColor="#8B7355"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widgetUpdated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="Not synced yet"
        android:textColor="#9A8873"
        android:textSize="11sp" />
</LinearLayout>
